import { neon } from "@neondatabase/serverless";

const sql = neon(process.env.DATABASE_URL);

export async function GET(req) {
  try {
    const { searchParams } = new URL(req.url);
    const tenantId = searchParams.get("tenant_id") || req.headers.get("x-tenant-id");

    if (!tenantId) {
      return Response.json({ error: "Tenant ID é obrigatório" }, { status: 400 });
    }

    const settings = await sql`
      SELECT * FROM tenant_settings
      WHERE tenant_id = ${parseInt(tenantId)}
      LIMIT 1
    `;

    if (settings.length === 0) {
      return Response.json({ error: "Configurações não encontradas" }, { status: 404 });
    }

    return Response.json(settings[0]);
  } catch (error) {
    console.error("Erro ao buscar configurações:", error);
    return Response.json({ error: error.message }, { status: 500 });
  }
}

export async function POST(req) {
  try {
    const tenantId = req.headers.get("x-tenant-id");

    if (!tenantId) {
      return Response.json({ error: "Tenant ID é obrigatório" }, { status: 400 });
    }

    const body = await req.json();

    const result = await sql`
      UPDATE tenant_settings
      SET 
        name = ${body.name || null},
        phone = ${body.phone || null},
        address = ${body.address || null},
        city = ${body.city || null},
        state = ${body.state || null},
        zip_code = ${body.zip_code || null},
        opening_time = ${body.opening_time || null},
        closing_time = ${body.closing_time || null},
        description = ${body.description || null},
        primary_color = ${body.primary_color || '#E50914'},
        secondary_color = ${body.secondary_color || '#000000'},
        accent_color = ${body.accent_color || '#FFFFFF'},
        logo_url = ${body.logo_url || null},
        banner_url = ${body.banner_url || null},
        updated_at = NOW()
      WHERE tenant_id = ${parseInt(tenantId)}
      RETURNING *
    `;

    if (result.length === 0) {
      return Response.json({ error: "Configurações não encontradas" }, { status: 404 });
    }

    return Response.json(result[0]);
  } catch (error) {
    console.error("Erro ao salvar configurações:", error);
    return Response.json({ error: error.message }, { status: 500 });
  }
}
